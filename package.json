{
  "name": "symbol-finder",
  "version": "1.0.0",
  "description": "Symbol finder algorithm for code navigation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "symbol-finder": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && esbuild src/opencode-tool.ts --bundle --outfile=dist/symbol-finder.js --format=esm --platform=node --external:fs --external:path",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:watch": "jest --watch",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "symbol",
    "finder",
    "code-navigation",
    "lsp"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
